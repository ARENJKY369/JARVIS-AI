# JARVIS OS — environment template
# Copy to .env and fill in secrets. Never commit .env.

# --- Core ---
JARVIS_ENVIRONMENT=development
JARVIS_DEBUG=false

# --- AI / LLM (Ollama local) ---
JARVIS_AI_PROVIDER=ollama
JARVIS_AI_OLLAMA_HOST=http://127.0.0.1:11434
JARVIS_AI_DEFAULT_MODEL=llama3.2
JARVIS_AI_VISION_MODEL=llava
JARVIS_AI_TEMPERATURE=0.7
JARVIS_AI_MAX_TOKENS=2048

# --- Database ---
JARVIS_DB_ENGINE=sqlite
JARVIS_DB_PATH=database/jarvis.db
JARVIS_DB_VECTOR_PATH=database/vector_store

# --- Voice ---
# formant = always-on offline multi-voice TTS
# piper   = neural (needs piper-tts + model under models/piper/)
# auto    = prefer piper, fall back to formant
JARVIS_VOICE_ENABLED=true
JARVIS_VOICE_TTS_ENGINE=auto
JARVIS_VOICE_TTS_MODEL=en_GB-alan-medium
# JARVIS_VOICE_PIPER_MODEL_PATH=/absolute/path/to/model.onnx
JARVIS_VOICE_STT_MODEL=base
JARVIS_VOICE_LANGUAGE=en
JARVIS_VOICE_DEVICE=cpu
JARVIS_VOICE_SPEAKING_RATE=0.95
JARVIS_VOICE_PITCH_HZ=105
# Default formant profile: jarvis | deep | aria | nova | friday | soft | sage | ...
# JARVIS_UI_DEFAULT_VOICE=jarvis

# --- Vision ---
JARVIS_VISION_ENABLED=true
JARVIS_VISION_OCR_ENGINE=tesseract

# --- Email skill (optional — drafts work without this) ---
# For Gmail: enable 2FA → create App Password → paste below
JARVIS_EMAIL_ENABLED=false
JARVIS_EMAIL_SMTP_HOST=smtp.gmail.com
JARVIS_EMAIL_SMTP_PORT=587
JARVIS_EMAIL_SMTP_USER=you@gmail.com
JARVIS_EMAIL_SMTP_PASSWORD=your-app-password
JARVIS_EMAIL_FROM=you@gmail.com
JARVIS_EMAIL_USE_TLS=true
JARVIS_EMAIL_REQUIRE_CONFIRMATION=true
JARVIS_EMAIL_DEFAULT_MODE=draft

# --- Security ---
JARVIS_SECURITY_SANDBOX_ENABLED=true
# Keep false unless you need SMTP / external network skills
JARVIS_SECURITY_ALLOW_NETWORK=false
JARVIS_SECURITY_MAX_EXECUTION_TIME=30

# --- Logging ---
JARVIS_LOG_LEVEL=INFO
JARVIS_LOG_FILE_ENABLED=true

# --- UI ---
JARVIS_UI_THEME=dark
JARVIS_UI_ANIMATION_SPEED=1.0
# JARVIS_UI_DEFAULT_VOICE=aria
